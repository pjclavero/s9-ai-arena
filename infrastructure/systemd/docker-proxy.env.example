# R-DEPLOY · R2 — configuración del proxy de la API de Docker (HOST VM108).
# Copiar a /etc/s9-ai-arena/docker-proxy.env y ajustar. Lo lee la unidad
# systemd s9-docker-proxy.service (EnvironmentFile).

# Dirección de escucha. NO uses 127.0.0.1 si el bot-manager corre en un
# contenedor: loopback del host no es alcanzable vía host-gateway. Usa la IP de
# la interfaz interna controlada (el gateway del bridge de Docker, típicamente
# docker0 = 172.17.0.1) y acótala por firewall a esa red. Ver docs/ops/docker-proxy.md.
DOCKER_PROXY_BIND=172.17.0.1
DOCKER_PROXY_PORT=2375

# Socket de Docker del host (único punto de contacto real con Docker).
DOCKER_SOCKET=/var/run/docker.sock

# Red Docker en la que el proxy permite crear contenedores de bots (allowlist).
# Debe coincidir con la red `arena` del stack (nombre real: <proyecto>_arena).
ARENA_NETWORK=s9-ai-arena_arena

# Usuario:grupo con el que el proxy fuerza a correr los contenedores de bots.
SANDBOX_USER=10001:10001

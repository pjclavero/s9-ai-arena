# ─────────────────────────────────────────────────────────────────────────────
# S9 AI Arena — configuración del stack (copiar a infrastructure/.env y editar)
# Los SECRETOS nunca van aquí: viven en infrastructure/secrets/ (por archivo,
# generados con scripts/init-secrets.sh) y el Compose los pasa como
# /run/secrets/*. Ver docs/despliegue.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Identidad y exposición ───────────────────────────────────────────────────
# Dominio público de la plataforma.
S9_DOMAIN=arena.seccionnueve.duckdns.org

# Puertos que publica el gateway (ÚNICO servicio con puertos al exterior).
# Modo (a) standalone: 80/443 directos.
# Modo (b) detrás del proxy de VM104: publicar solo HTTP a la LAN (p. ej. 8080)
#   y dejar que vm104-web-hosting termine TLS. Ver docs/despliegue.md.
HTTP_PORT=80
HTTPS_PORT=443

# Configuración del gateway:
#   nginx.conf               → modo (a) standalone (TLS en el gateway).
#   nginx-behind-proxy.conf  → modo (b) detrás del Nginx de VM104.
GATEWAY_CONF=nginx.conf

# Saltos de proxy de confianza delante de la API (R1.8 · ERR-SEC-05).
# Determina de qué X-Forwarded-For se fía Express para calcular la IP real del
# cliente (cuota anónima y bloqueo de fuerza bruta de login). SIEMPRE un número
# acotado de saltos, nunca una confianza genérica:
#   1 → modo (a) standalone: solo el gateway del stack (por defecto en Compose).
#   2 → modo (b) detrás de VM104: Nginx de VM104 + gateway del stack.
#       Requiere que VM104 envíe `X-Forwarded-For $proxy_add_x_forwarded_for`.
#TRUST_PROXY_HOPS=1

# ── Perfiles ─────────────────────────────────────────────────────────────────
# Alternativa a --profile en la CLI. Combinaciones típicas:
#   COMPOSE_PROFILES=production                producción con Postgres en contenedor
#   COMPOSE_PROFILES=external-db               producción con PostgreSQL externo (DATABASE_URL)
#   COMPOSE_PROFILES=production,observability  producción + Prometheus/Grafana/Loki
#   COMPOSE_PROFILES=development               desarrollo
#   COMPOSE_PROFILES=production,streaming      producción + streamer de YouTube
#COMPOSE_PROFILES=production

# ── Base de datos ────────────────────────────────────────────────────────────
# Vacío → Postgres del stack (servicio postgres, perfiles development/production).
# Con valor + perfil external-db → instancia PostgreSQL existente del servidor
# y el servicio postgres NO arranca (nota del dosier 6.2).
#   p. ej. DATABASE_URL=postgresql://arena@192.168.1.205:5432/arena
#   (la contraseña, por secreto/`.pgpass` del lado del cliente; nunca aquí)
DATABASE_URL=

# ── Imágenes ─────────────────────────────────────────────────────────────────
# Prefijo del registro y tag a desplegar (la CI publica sha-<commit> y v<versión>).
IMAGE_PREFIX=ghcr.io/pjclavero/s9-ai-arena
TAG=latest

# ── Entrypoints de servicios (los fija cada equipo cuando entrega) ──────────
#WEB_ENTRY=apps/web/src/main.ts
#API_ENTRY=apps/api/src/main.ts
#ENGINE_ENTRY=apps/arena-engine/src/cli.ts
#WORKER_ENTRY=apps/tournament-worker/src/main.ts
#BOT_MANAGER_ENTRY=apps/bot-manager/src/main.ts
#MAP_SERVICE_ENTRY=apps/map-service/src/main.ts
#REPLAY_SERVICE_ENTRY=apps/replay-service/src/main.ts

# ── Streaming (perfil streaming, E11) ────────────────────────────────────────
#BROADCAST_URL=http://web:3000/broadcast
#RTMPS_URL=rtmps://a.rtmps.youtube.com/live2
# La stream key va en secrets/stream_key.txt, NUNCA aquí.

# ── Observabilidad (perfil observability, cap. 24) ───────────────────────────
# Webhook al que Alertmanager envía las alertas (Slack/Matrix/ntfy del operador).
#ALERT_WEBHOOK_URL=
# Email alternativo (requiere SMTP del operador en alertmanager.yml).
#ALERT_EMAIL=
# Con BD externa (perfil external-db), a dónde apunta postgres-exporter:
#PG_EXPORTER_URI=192.168.1.205:5432/arena?sslmode=disable

# ── Copias de seguridad (T10.4) ──────────────────────────────────────────────
# Repositorio restic designado por el operador (NAS/ZFS del servidor).
#   p. ej. RESTIC_REPOSITORY=sftp:backup@192.168.1.210:/backups/s9-ai-arena
#   o      RESTIC_REPOSITORY=/mnt/nas/backups/s9-ai-arena (montado en la VM)
RESTIC_REPOSITORY=
# Cron del backup diario (formato crontab, hora local del contenedor).
BACKUP_CRON=15 4 * * *
# Retención de replays oficiales en el backup (días); el resto no se copia.
REPLAY_RETENTION_DAYS=180

{
  "uid": "s9-plataforma",
  "title": "S9 AI Arena · Plataforma",
  "tags": ["s9-arena", "e10"],
  "schemaVersion": 39,
  "editable": false,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Motor · ticks/s",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "arena_engine_ticks_per_second", "legendFormat": "ticks/s" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Motor · retraso de tick (s)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "arena_engine_tick_delay_seconds", "legendFormat": "retraso" },
        { "refId": "B", "expr": "time() - arena_engine_last_tick_timestamp_seconds", "legendFormat": "desde el último tick" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Colas · profundidad",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "arena_queue_depth", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Builds · duración y resultado",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(s9_build_duration_seconds_bucket[10m])))", "legendFormat": "p95 duración" },
        { "refId": "B", "expr": "sum by (result) (rate(s9_build_result_total[10m]))", "legendFormat": "builds {{result}}/s" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU por servicio",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[5m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RAM por servicio",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Errores por endpoint (5xx)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, route) (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{service}} {{route}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs (filtrar por correlation_id con | json | correlation_id=\"…\")",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "{job=\"docker\"} | json" }
      ]
    }
  ]
}

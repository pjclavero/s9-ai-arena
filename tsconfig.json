{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "bundler",
    "strict": false, "esModuleInterop": true, "skipLibCheck": true,
    "resolveJsonModule": true, "allowImportingTsExtensions": true, "noEmit": true
  },
  "include": ["apps/**/*", "packages/**/*"]
}
